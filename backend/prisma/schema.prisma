generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String
  employees Employee[]
}

model Employee {
  id     Int    @id @default(autoincrement())
  name   String
  email  String
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id])
}